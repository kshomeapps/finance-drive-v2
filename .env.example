# ============================================================================
# Finance Drive v2 - 環境變數配置
# ============================================================================
# 安全警告: 請勿將 .env 文件提交至版本控制！
# 此文件 (.env.example) 可以提交，但 .env 不可以。

# ============================================================================
# 後端設定
# ============================================================================
PORT=5000
NODE_ENV=development

# 前端 URL（開發環境）
FRONTEND_URL=http://localhost:3000

# ============================================================================
# JWT 密鑰（生產環境請使用強隨機字串，至少 32 字元）
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================
JWT_SECRET=your-super-secret-access-token-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-32-chars

# ============================================================================
# 資料庫設定
# ============================================================================
# 開發環境: SQLite（零配置，文件式資料庫）
DATABASE_URL=sqlite://./data.sqlite

# 生產環境選項（免費方案）:
# 1. Render.com 持久磁碟 SQLite（免費，但有休眠限制）:
#    DATABASE_URL=sqlite:///opt/render/project/src/data/finance.sqlite
#
# 2. Neon PostgreSQL（免費 0.5GB）:
#    DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require
#
# 3. Supabase PostgreSQL（免費 500MB）:
#    DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# ============================================================================
# 前端設定（Vite 環境變數，需以 VITE_ 開頭）
# ============================================================================
# 生產環境後端 API URL（如果前後端分開部署）
# VITE_API_URL=https://your-backend.onrender.com
