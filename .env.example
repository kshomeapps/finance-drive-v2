# ============================================================================
# Finance Drive v2 - Environment Configuration
# ============================================================================
# SECURITY WARNING: Never commit .env file to version control!

# Backend
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT (generate strong random strings for production)
JWT_SECRET=your-super-secret-access-token-key-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-min-32-chars

# Database
# Development: SQLite (file-based, zero config)
# Production: PostgreSQL (Neon, Supabase, Railway, Render)
DATABASE_URL=sqlite://./data.sqlite

# Optional: For production PostgreSQL
# DATABASE_URL=postgresql://user:password@host:5432/finance_db
